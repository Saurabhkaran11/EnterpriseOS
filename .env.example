# Optional override; no credentials are required.
NEXT_PUBLIC_API_URL=http://localhost:8000
ENTERPRISEOS_MODE=DEMO

# H Company computer use. Mock mode is safe and fully functional by default.
HCOMPANY_API_KEY=
HAI_API_KEY=
HCOMPANY_BASE_URL=https://agp.hcompany.ai
HCOMPANY_MODEL=h/web-surfer-pro
HCOMPANY_TIMEOUT_SECONDS=30
HCOMPANY_MOCK_MODE=true
HCOMPANY_MAX_ACTIONS=12
ENTERPRISEOS_PUBLIC_URL=

# NVIDIA reasoning. Exactly one model is used; mock mode requires no key.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_TIMEOUT_SECONDS=30
NVIDIA_MOCK_MODE=true

# Amazon S3 artifact storage. Local mode is the credential-free default.
AWS_REGION=us-west-2
AWS_S3_BUCKET=
AWS_USE_LOCAL_MODE=true
